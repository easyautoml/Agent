graph LR
    subgraph "Without Memory - Each turn is isolated"
        U1["Hi, I am Alice"] --> LLM1["LLM"]
        U2["What is my name?"] --> LLM2["LLM"]
        LLM2 --> R1["I do not know your name."]
    end

    subgraph "With Memory - Context carries over"
