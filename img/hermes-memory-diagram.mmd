        SUMM["3. LLM Summarisation\n(cheap/fast model)\nparallel per session\ncentered on match\nmax 100k chars"]:::layer2
    end

    %% в”Ђв”Ђ LAYER 3: Honcho User Modelling в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    subgraph L3["рџ§   Layer 3 вЂ” Honcho User Modelling   (optional, cloud)"]
