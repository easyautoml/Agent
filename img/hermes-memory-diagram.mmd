        WAL["WAL Mode\nConcurrent readers\n+ single writer\nJitter retry on lock\nCheckpoint every 50 writes"]:::layer2
    end

    %% SESSION SEARCH
    subgraph SRCH["рџ”Ќ  Session Search Tool"]
        direction TB
        FTS5Q["1. FTS5 query\ntop 50 ranked matches"]:::layer2
