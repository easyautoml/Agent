flowchart TB
    classDef ui     fill:#1e3a5f,stroke:#4a90d9,color:#fff
    classDef core   fill:#163020,stroke:#52b788,color:#bef0cc
    classDef sdk    fill:#2a1a3e,stroke:#9b59b6,color:#e8d0ff
    classDef ext    fill:#3e2a1a,stroke:#e67e22,color:#ffe0cc
