        POLICY["Exec Policy\n& Approval"]:::core
        MEM["Memory Pipeline\n(2-phase)"]:::core
        SAND["Sandbox Layer"]:::core
    end

    subgraph MODELS["AI Models"]
        OAI["OpenAI\nResponses API"]:::ext
        ANT["Anthropic"]:::ext
        LOC["Local LLMs\n(Ollama, LM Studio)"]:::ext
