    subgraph FRONT["User Interfaces"]
        TUI["Terminal UI\n(Ratatui / Rust)"]:::ui
        EXEC["Exec Mode\n(headless / CI)"]:::ui
        IDE["IDE Extension\n(VS Code, Cursor)"]:::ui
    end

    subgraph SDKS["SDKs"]
        PY["Python SDK"]:::sdk
        TS["TypeScript SDK"]:::sdk
    end

    APP["App-Server\nJSON-RPC v2"]:::core

    subgraph CORE["codex-core  (Rust library)"]
