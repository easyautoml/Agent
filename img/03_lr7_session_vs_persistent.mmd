        PM2["LangChain File backend"]
        PM3["CrewAI LanceDB (default)"]
        PM4["CrewAI Qdrant Edge (distributed)"]
    end

    subgraph SEMANTIC["Semantic / Vector Memory\n(search by meaning)"]
        VM1["LangChain VectorStoreRetrieverMemory\n+ FAISS / Pinecone / Chroma"]
        VM2["CrewAI all records indexed as vectors\n(built-in, always on)"]
    end
