graph LR
    subgraph SESSION["Session Memory\n(dies when process ends)"]
        SM1["LangChain InMemory backend"]
        SM2["CrewAI without persistence config"]
    end

    subgraph PERSISTENT["Persistent Memory\n(survives restarts)"]
